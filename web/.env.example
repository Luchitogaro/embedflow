# Optional: skip monthly upload caps for specific users (only when NODE_ENV=development,
# or set EMBEDFLOW_ALLOW_QUOTA_BYPASS=true — avoid enabling bypass in production).
# Use EMAILS for addresses; USER_IDS expects Supabase auth UUIDs (not email — unless you typo an email
# in USER_IDS, the app treats @ entries as emails for dev convenience).
# EMBEDFLOW_DEV_QUOTA_BYPASS_EMAILS=you@example.com,other@example.com
# EMBEDFLOW_DEV_QUOTA_BYPASS_USER_IDS=uuid-from-auth-users-table
# EMBEDFLOW_ALLOW_QUOTA_BYPASS=true

# Optional: simulate a paid plan for feature gates (only with NODE_ENV=development or EMBEDFLOW_ALLOW_PLAN_BYPASS=true).
# Values: free | starter | pro | team | enterprise. Also set the same EMBEDFLOW_DEV_PLAN_OVERRIDE on the worker .env
# (ENVIRONMENT=development or EMBEDFLOW_ALLOW_PLAN_BYPASS=true) so pitch / Slack / enterprise model match.
# EMBEDFLOW_ALLOW_PLAN_BYPASS=true
# EMBEDFLOW_DEV_PLAN_OVERRIDE=pro

# Billing: unset or any value except the string "false" shows the “coming soon” billing UI (no checkout/portal).
# Set to false when Stripe / Mercado Pago is production-ready.
# EMBEDFLOW_BILLING_COMING_SOON=false

# Public URL of this Next.js app (billing redirects, OG, sitemap). On Railway you can set this to your generated domain.
# NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app

# Worker integration (required when enqueueing analysis jobs)
# WORKER_URL=http://localhost:8000
# WORKER_SHARED_SECRET=change-me-in-all-environments

# Share link governance (days until shared analysis link expires)
# SHARE_LINK_TTL_DAYS=30

# Preference changes (theme / language) fire window event "embedflow:preference-change", push to dataLayer
# (event "embedflow_preference_change"), gtag, or plausible if those globals exist, and append to
# localStorage key embedflow_preference_events_v1 (last 80 events) — no extra env vars required.

# Playwright E2E (optional): set both to run authenticated dashboard tests (local or CI with real Supabase)
# E2E_USER_EMAIL=
# E2E_USER_PASSWORD=
# Use the same host as manual testing (localhost and 127.0.0.1 do not share cookies).
# E2E_BASE_URL=http://localhost:3000

# Billing (Next.js): Stripe (default) or Mercado Pago (Colombia — PSE + cards via Checkout Pro).
# Webhooks need SUPABASE_SERVICE_ROLE_KEY (same as Stripe webhook route).
# BILLING_PROVIDER=stripe
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_WEBHOOK_SECRET=
# Amounts in whole COP for Checkout Pro items:
# MERCADOPAGO_AMOUNT_STARTER=99000
# MERCADOPAGO_AMOUNT_PRO=199000
# MERCADOPAGO_AMOUNT_TEAM=599000
# MERCADOPAGO_CURRENCY_ID=COP
# MERCADOPAGO_PLAN_PERIOD_DAYS=30
# MERCADOPAGO_USE_SANDBOX_INIT_POINT=false
