# Optional: skip monthly upload caps for specific users (only when NODE_ENV=development,
# or set EMBEDFLOW_ALLOW_QUOTA_BYPASS=true — avoid enabling bypass in production).
# EMBEDFLOW_DEV_QUOTA_BYPASS_EMAILS=you@example.com,other@example.com
# EMBEDFLOW_DEV_QUOTA_BYPASS_USER_IDS=supabase-auth-user-uuid
# EMBEDFLOW_ALLOW_QUOTA_BYPASS=true

# Worker integration (required when enqueueing analysis jobs)
# WORKER_URL=http://localhost:8000
# WORKER_SHARED_SECRET=change-me-in-all-environments

# Share link governance (days until shared analysis link expires)
# SHARE_LINK_TTL_DAYS=30

# Playwright E2E (optional): set both to run authenticated dashboard tests (local or CI with real Supabase)
# E2E_USER_EMAIL=
# E2E_USER_PASSWORD=
# Use the same host as manual testing (localhost and 127.0.0.1 do not share cookies).
# E2E_BASE_URL=http://localhost:3000
