# Embedflow Worker Environment Variables
# Copy to .env and fill in values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
# Retries (transient 429/5xx/timeouts) and per-call timeout (seconds)
OPENAI_MAX_RETRIES=5
OPENAI_CALL_TIMEOUT_SEC=180
# Single-shot extraction uses full text up to this length; longer contracts use chunked map→merge.
OPENAI_EXTRACTION_MAX_INPUT_CHARS=45000
# When text length exceeds this, run chunked extraction (defaults to same as MAX above).
OPENAI_EXTRACTION_CHUNK_THRESHOLD=45000
# Soft cap on extracted text before analysis: auto = same coverage as chunked map (hard_max × max_chunks); 0 = disable.
OPENAI_MAX_EXTRACTED_CHARS=auto
# Map step: larger windows = fewer API calls (watch TPM per request).
OPENAI_CHUNK_CHAR_SIZE=52000
OPENAI_CHUNK_OVERLAP=2000
# Cap map calls: widen windows up to hard_max, then truncate tail if still too long.
OPENAI_CHUNK_MAX_COUNT=72
OPENAI_CHUNK_HARD_MAX=80000
# Parallel map-phase calls (1=sequential). Raise for speed; lower if you see 429s.
OPENAI_CHUNK_MAP_CONCURRENCY=2
# Map step (cheap) vs merge + default chat (quality)
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_CHUNK=gpt-4o-mini
OPENAI_MODEL_MERGE=gpt-4o
# Contract excerpt size for the pitch step (default 30k chars)
OPENAI_PITCH_CONTEXT_CHARS=30000

# Redis (optional; jobs still run in the FastAPI process via BackgroundTasks)
REDIS_URL=redis://localhost:6379
# USE_REDIS=true only adds a BullMQ publish; analysis runs in-process unless you add an external consumer.

# Large PDF download timeout (seconds) when fetching from Supabase Storage
PDF_DOWNLOAD_TIMEOUT_SEC=300

# Worker
WORKER_PORT=8000
ENVIRONMENT=development
WORKER_SHARED_SECRET=change-me-in-all-environments

# Optional: email when analysis completes (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
# en or es — copy for analysis-ready email
RESEND_EMAIL_LOCALE=en
# Public URL of the Next.js app (used in email links)
APP_URL=http://localhost:3000
